Nelson',  'Michael J. Fox',  'John Stamos', 'Barbra Streisand'],\n\t\t'Entertainer': ['Anthony Bourdain',  'Tina Fey',  'Johnny Cash',  'Jim Carroll',  'Keith Richards',  'Henry Winkler',  'Robin Williams',  'Willie Nelson',  'Michael J. Fox',  'John Stamos', 'Barbra Streisand']\n\n    };\n\t\n\tfunction formatPercentage(number) {\n    return Math.round(number).toString();\n\t}\n\n    \n\t\/\/ Retrieve selected biographies\n\tfunction getSelectedBiographies() {\n\t\treturn [\n\t\t\tQualtrics.SurveyEngine.getEmbeddedData('choice-1'),\n\t\t\tQualtrics.SurveyEngine.getEmbeddedData('choice-2'),\n\t\t\tQualtrics.SurveyEngine.getEmbeddedData('choice-3'),\n\t\t\tQualtrics.SurveyEngine.getEmbeddedData('choice-4'),\n\t\t\tQualtrics.SurveyEngine.getEmbeddedData('choice-5'),\n\t\t\tQualtrics.SurveyEngine.getEmbeddedData('choice-6')\n\t\t];\n\t}\n    var selectedBiographies = getSelectedBiographies();\n    console.log(selectedBiographies);\n\n    var cond = Qualtrics.SurveyEngine.getEmbeddedData('cond');\n\n    var biographiesInCategories = {\n        'Women': selectedBiographies.filter(biography => categories.Women.includes(biography)),\n        'Pages': selectedBiographies.filter(biography => categories.Pages.includes(biography)),\n        'Years': selectedBiographies.filter(biography => categories.Years.includes(biography)),\n        'Entertainer': selectedBiographies.filter(biography => categories.Entertainer.includes(biography))\n    };\n\n    console.log(biographiesInCategories);\n\n\t\tfunction calculatePercent(selectedBiographies, categoryBiographies) {\n\n\t\t\tvar count = 0;\n\t\t\tfor (let biography of selectedBiographies) {\n\t\t\t\tif (categoryBiographies.includes(biography)) {\n\t\t\t\t\tcount++;\n\t\t\t\t\tconsole.log(\"Matched biography:\", biography);\n\t\t\t\t}\n\t\t\t}\n\t\t\tconsole.log('Count for category:', count);\n\t\t\tvar percent = (count \/ selectedBiographies.length * 100).toFixed(2);\n\t\t\tconsole.log('Calculated Percent:', percent);\n\t\t\treturn 