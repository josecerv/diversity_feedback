nction() {\n        var x = Math.sin(seed++) * 10000;\n        return x - Math.floor(x);\n    };\n\n    while (m) {\n        i = Math.floor(random() * m--);\n\n        t = array[m];\n        array[m] = array[i];\n        array[i] = t;\n    }\n}\n\tclass Biography {\n\t\tconstructor(name, published, about, who, description, link, pages) {\n\t\t\tthis.name = name;\n\t\t\tthis.published = published;\n\t\t\tthis.about = about;\n\t\t\tthis.who = who;\n\t\t\tthis.description = description;\n\t\t\tthis.link = link;\n\t\t\tthis.pages = pages;\n\t\t}\n\t}\n\nconst biographies = [\n    new Biography(\"Steve Jobs\", \"Published in 2011.\", \"A biography of\", \"Who was he?\", \"Apple Co-Founder\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_yqilFqdkilOTHaQ\", \"(656 pages)\"),\n    new Biography(\"J. Robert Oppenheimer\", \"Published in 2006.\", \"A biography of\", \"Who was he?\", \"Theoretical Physicist\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_HgsYywPRJz7tjx9\", \"(721 pages)\"),\n    new Biography(\"Mark Twain\", \"Published in 2010.\", \"A biography of\", \"Who was he?\", \"Writer\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_Pk1VamfdepoVuwu\", \"(736 pages)\"),\n    new Biography(\"Nelson Mandela\", \"Published in 1995.\", \"A biography of\", \"Who was he?\", \"Anti-apartheid Revolutionary\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_d0TCr4hakXiXaAi\", \"(656 pages)\"),\n    new Biography(\"Anthony Bourdain\", \"Published in 2007.\", \"A biography of\", \"Who was he?\", \"Chef and TV Personality\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_x2ua91RF5OgER9f\", \"(312 pages)\"),\n    new Biography(\"Andrew Jackson\", \"Published in 2009.\", \"A biography of\", \"Who was he?\", \"7th U.S. President\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_52wiJpWCDFiEmc8\", \"(512 pages)\"),\n    new Biography(\"Anne Frank\", \"Published in 1993.\", \"A biography of\", \"Who was she?\", \"Diarist during the Holocaust\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_Iaay9nCelm4YLfG\", \"(283 pages)\"),\n    new Biography(\"Tina Fey\", \"Published in 2013.\", \"A biography of\", \"Who is she?\", \"Comedian and Actress\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_WXqnDon0GOmaHBY\", \"(272 pages)\"),\n    new Biography(\"Johnny Cash\", \"Published in 2003.\", \"A biography of\", \"Who was he?\", \"Musician\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_aUVsyNGh0ZA3D7G\", \"(320 pages)\"),\n    new Biography(\"Jackie Kennedy\", \"Published in 2023.\", \"A biography of\", \"Who was she?\", \"Former First Lady\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_yAEGrb9an0zaD3A\", \"(511 pages)\"),\n    new Biography(\"Helen Keller\", \"Published in 1996.\", \"A biography of\", \"Who was she?\", \"Author and Activist\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_rf3mtX6ADq1usWk\", \"(80 pages)\"),\n    new Biography(\"Barbra Streisand\", \"Published in 2023.\", \"A biography of\", \"Who was she?\", \"Singer and Actress\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_hQ3k8WgOnpmDE59\", \"(992 pages)\"),\n    new Biography(\"Theodore Roosevelt\", \"Published in 2001.\", \"A biography of\", \"Who was he?\", \"26th U.S. President\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_iIPoKPcw48SkuwE\", \"(920 pages)\"),\n    new Biography(\"Che Guevara\", \"Published in 2003.\", \"A biography of\", \"Who was he?\", \"Revolutionary Leader\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_FRkRIpb5oAo8OOH\", \"(175 pages)\"),\n    new Biography(\"Jim Carroll\", \"Published in 1987.\", \"A biography of\", \"Who was he?\", \"Author\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_H90vJRN6zIsPOjH\", \"(224 pages)\"),\n    new Biography(\"Tennessee Williams\", \"Published in 2014.\", \"A biography of\", \"Who was he?\", \"Playwright\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_y2sjhiIwjXjcAjd\", \"(784 pages)\"),\n    new Biography(\"Keith Richards\", \"Published in 2011.\", \"A biography of\", \"Who is he?\", \"Musician\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_cp1EMKpaN6uTgUV\", \"(576 pages)\"),\n    new Biography(\"Napoleon Bonaparte\", \"Published in 2014.\", \"A biography of\", \"Who was he?\", \"Military Leader\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_IASY65r8ouijJls\", \"(976 pages)\"),\n    new Biography(\"Andre Agassi\", \"Published in 2010.\", \"A biography of\", \"Who is he?\", \"Tennis Player\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_LrAE1vpAlhW3aaR\", \"(400 pages)\"),\n    new Biography(\"Thomas Jefferson\", \"Published in 1998.\", \"A biography of\", \"Who was he?\", \"3rd U.S. President\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_CyUSCS5ZlWej6MG\", \"(440 pages)\"),\n    new Biography(\"Henry Winkler\", \"Published in 2023.\", \"A biography of\", \"Who is he?\", \"Actor\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_mgZNfgp2gNCYKZO\", \"(256 pages)\"),\n    new Biography(\"Robin Williams\", \"Published in 2019.\", \"A biography of\", \"Who was he?\", \"Comedian and Actor\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_xaFZJD8AZ2jec4L\", \"(560 pages)\"),\n    new Biography(\"Willie Nelson\", \"Published in 2016.\", \"A biography of\", \"Who is he?\", \"Musician\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_6wjrqgozeJnJ2hq\", \"(400 pages)\"),\n    new Biography(\"Michael J. Fox\", \"Published in 2020.\", \"A biography of\", \"Who is he?\", \"Actor\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_FtO0vTLADtDKjvO\", \"(256 pages)\"),\n    new Biography(\"John Stamos\", \"Published in 2023.\", \"A biography of\", \"Who is he?\", \"Actor and Musician\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_MVZx0AOpmnXCPfM\", \"(342 pages)\")\n];\n\n\t\n\tshuffleArray(biographies, seed);\n\t\n\t\/\/ Create a table and style it\n    var table = document.createElement('table');\n    table.style.borderCollapse = 'collapse';\n    table.style.width = '100%';\n    table.style.color = 'black';\n\n    \/\/ Calculate rows and columns\n    var rows = 5;\n    var cols = 5;\n    var selectedBiographies = [];\n\n\tfunction handleBiographyClick(cell, biographyName) {\n\t\t\/\/ If the cell is a previous choice, do nothing.\n\t\tif (cell.classList.contains('previous-choice')) {\n\t\t\treturn;\n\t\t}\n\n\t\t\/\/ If the cell is already selected, deselect it.\n\t\tif (cell.classList.contains('selected')) {\n\t\t\tcell.classList.remove('selected');\n\t\t\tlet biographyIndex = selectedBiographies.indexOf(biographyName);\n\t\t\tif (biographyIndex > -1) {\n\t\t\t\tselectedBiographies.splice(biographyIndex, 1);\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('choice-7', null);\n\t\t\t}\n\t\t\tcheckSelections();\n\t\t\treturn;\n\t\t}\n\n\t\t\/\/ If no biography is selected yet, add the 'selected' class to the clicked cell.\n\t\tif (selectedBiographies.length < 1) {\n\t\t\tcell.classList.add('selected');\n\t\t\tselectedBiographies.push(biographyName);\n\t\t\tif (selectedBiographies.length === 1) {\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('choice-7', selectedBiographies[0]);\n\t\t\t}\n\t\t\tcheckSelections();\n\t\t}\n\t}\n\n\n\t\/\/ Function to check whether 1 biography is selected\n\tfunction checkSelections() {\n\t\tlet nextButton = document.querySelector('#NextButton');\n\t\tif (selectedBiographies.length === 1) {\n\t\t\tnextButton.style.pointerEvents = 'auto';\n\t\t\tnextButton.style.opacity = '1';\n\t\t} else {\n\t\t\tnextButton.style.pointerEvents = 'none';\n\t\t\tnextButton.style.opacity = '0.5';\n\t\t}\n\t}\n\n\t\/\/ Initially disable the NextButton\n\tcheckSelections();\n\t\n\n\t\n\t    for (var i = 0; i < rows; i++) {\n        var row = document.createElement('tr');\n        \tfor (var j = 0; j < cols; j++) {\n            var index = i * cols + j;\n\n\t\t\tvar biography = biographies[index];\n\n            var cell = document.createElement('td');\n\t\t\tif (biography && previousChoices.includes(biography.name)) {\n                cell.classList.add('previous-choice');\n                cell.style.backgroundColor = 'gray';\n            }\n\n            if (index < biographies.length) {\n                var biography = biographies[index];\n\n                \/\/ Create img element and add the link\n                var img = document.createElement('img');\n                img.src = biography.link;\n                img.style.width = '100px';\n\t\t\t\timg.style.display = 'block'; \/\/ To ensure it takes up the full width when centered\n            \timg.style.margin = '0 auto'; \/\/ To center the image\n\n\t\t\t\/\/ Add img and other details to cell\n\t\t\tcell.innerHTML = img.outerHTML + \"<br>\" + \n\t\t\t\tbiography.about + \"<br>\" + \n\t\t\t\t\"<b>\" + biography.name + \"<\/b><br>\" + \n\t\t\t\tbiography.pages + \"<br>\" + \n\t\t\t\tbiography.published + \"<br>\" + \n\t\t\t\t\"<u>\" + biography.who + \"<\/u><br>\" +\n\t\t\t\tbiography.description + \"\";\n\n                \/\/ Add click event to select the biography from the table\n                cell.addEventListener('click', function(biographyName) {\n                    return function() {\n                        handleBiographyClick(this, biographyName);\n                    };\n                }(biography.name)); \/\/ Pass the current biography name into the event function\n            }\n\n            \/\/ Style cell\n            cell.style.border = '1px solid black';\n            cell.style.padding = '10px';\n            cell.style.cursor = 'pointer';\n\t\t\tcell.style.textAlign = 'center';     \/\/ Center align content horizontally\n        \tcell.style.verticalAlign = 'top';    \/\/ Top align content vertically\n            row.appendChild(cell);\n        }\n        table.appendChild(row);\n    }\n\t\n\t\/\/ Check if biography is in the previousChoices\n\tif (previousChoices.includes(biography.name)) {\n\t\tcell.classList.add('previous-choice');\n\t\tcell.style.border = '1px solid black';\n        cell.style.padding = '10px';\n        cell.style.cursor = 'pointer';\n        cell.style.textAlign = 'center';     \/\/ Center align content horizontally\n        cell.style.verticalAlign = 'top';    \/\/ Top align content vertically\n\t}\n\n\t\n\t\n\n\/\/ Additional styles for the previous-choice class\nvar style = document.createElement('style');\nstyle.innerHTML = `\n    td.previous-choice {\n        background-color: #CCCCCC; \/\/ Gray color for already selected choices\n        cursor: not-allowed;\n    }\n    td.selected {\n        background-color: #ffdd99; \/\/ Light green for the newly selected choice\n    }\n`;\n\n\tdocument.head.appendChild(style);\n\t    \/\/ Add the table to the survey question\n    this.getQuestionContainer().appendChild(table);\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_1BJC5tq7iCTDLpk","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"Thank you for taking the survey. Please feel free to leave any comments or feedback!","TertiaryAttribute":null,"Payload":{"Configuration":{"InputHeight":65,"InputWidth":299,"QuestionDescriptionOption":"UseText"},"DataExportTag":"end","DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Thank you for taking the surv