ate":false,"Hidden":false}}},{"SurveyID":"SV_1BJC5tq7iCTDLpk","Element":"SQ","PrimaryAttribute":"QID19","SecondaryAttribute":"How many years of work experience do you have?","TertiaryAttribute":null,"Payload":{"Configuration":{"InputHeight":29,"InputWidth":161,"QuestionDescriptionOption":"UseText"},"DataExportTag":"work_exp","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":29,"QuestionDescription":"How many years of work experience do you have?","QuestionID":"QID19","QuestionText":"How many years of work experience do you have?","QuestionText_Unsafe":"How many years of work experience do you have?","QuestionType":"TE","SearchSource":{"AllowFreeResponse":"false"},"Selector":"SL","Validation":{"Settings":{"ContentType":"ValidNumber","ForceResponse":"ON","ForceResponseType":"ON","MinChars":"1","Type":"ContentType","ValidDateType":"DateWithFormat","ValidNumber":{"Max":"","Min":"","NumDecimals":""},"ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip"}}}},{"SurveyID":"SV_1BJC5tq7iCTDLpk","Element":"SQ","PrimaryAttribute":"QID9","SecondaryAttribute":"Informed Consent You are being asked to complete a survey as part of a research study about human...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[],"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"consent","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Informed Consent You are being asked to complete a survey as part of a research study about human...","QuestionID":"QID9","QuestionText":"<div style=\"text-align: center;\"><b>Informed Consent<\/b><\/div>\n<br>\nYou are being asked to complete a survey as part of a research study about human behavior and decision-making. Your participation in this study is entirely voluntary. If you elect to participate, you will be asked to select an advisory panel based on a pool of options. You will then be asked to answer a series of survey questions. Additional information will be provided to you during your study participation.<br>\n<br>\nThis survey should take about 3 minutes. You can withdraw from the study at any time. If you decide to withdraw from the survey, your data will be destroyed. We will not share or store any data beyond the use of this research project.<br>\n<br>\nWe will make every effort to keep all the information you tell us during the study strictly confidential, except as required by law. Worker IDs will be collected strictly on the basis of compensation. Your name and other identifying information will never be connected with the responses you provide so no one will ever be able to identify you in any publications that will result from this research. If you have questions, concerns, or complaints regarding your confidentiality or if you have any questions about your rights as a research participant, you should e-mail the researcher at josecerv@wharton.upenn.edu. If a member of the research team cannot be reached or you want to talk to someone other than those working on the study, you may contact the Office of Regulatory Affairs with any questions, concerns, or complaints at the University of Pennsylvania by calling (215) 898-2614.<br>\n<br>\nIf you agree to participate, please click the arrow to continue. Otherwise, you may close the browser or navigate away from the page.","QuestionText_Unsafe":"<div style=\"text-align: center;\"><b>Informed Consent<\/b><\/div>\n<br>\nYou are being asked to complete a survey as part of a research study about human behavior and decision-making. Your participation in this study is entirely voluntary. If you elect to participate, you will be asked to select an advisory panel based on a pool of options. You will then be asked to answer a series of survey questions. Additional information will be provided to you during your study participation.<br>\n<br>\nThis survey should take about 5 minutes. You can withdraw from the study at any time. If you decide to withdraw from the survey, your data will be destroyed. We will not share or store any data beyond the use of this research project.<br>\n<br>\nWe will make every effort to keep all the information you tell us during the study strictly confidential, except as required by law. Worker IDs will be collected strictly on the basis of compensation. Your name and other identifying information will never be connected with the responses you provide so no one will ever be able to identify you in any publications that will result from this research. If you have questions, concerns, or complaints regarding your confidentiality or if you have any questions about your rights as a research participant, you should e-mail the researcher at josecerv@wharton.upenn.edu. If a member of the research team cannot be reached or you want to talk to someone other than those working on the study, you may contact the Office of Regulatory Affairs with any questions, concerns, or complaints at the University of Pennsylvania by calling (215) 898-2614.<br>\n<br>\nIf you agree to participate, please click the arrow to continue. Otherwise, you may close the browser or navigate away from the page.","QuestionType":"DB","Selector":"TB","Validation":{"Settings":{"Type":"None"}}}},{"SurveyID":"SV_1BJC5tq7iCTDLpk","Element":"SQ","PrimaryAttribute":"QID6","SecondaryAttribute":"Please check the box below to proceed.","TertiaryAttribute":null,"Payload":{"Configuration":{"Align":"left","QuestionDescriptionOption":"UseText","Theme":"light"},"DataExportTag":"captcha","DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Please check the box below to proceed.","QuestionID":"QID6","QuestionText":"Please check the box below to proceed.","QuestionText_Unsafe":"Please check the box below to proceed.","QuestionType":"Captcha","Selector":"V2"}},{"SurveyID":"SV_1BJC5tq7i