8RpoNka","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"&nbsp;","QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n\t\n\tlet seed = Math.floor(Math.random() * 100000);\n\tQualtrics.SurveyEngine.setEmbeddedData('randomSeed', seed);\n\n\n\t\n\tfunction shuffleArray(array, seed) {\n    var m = array.length, t, i;\n\n    \/\/ Use the seed to have consistent random values\n    var random = function() {\n        var x = Math.sin(seed++) * 10000;\n        return x - Math.floor(x);\n    };\n\n    while (m) {\n        i = Math.floor(random() * m--);\n\n        t = array[m];\n        array[m] = array[i];\n        array[i] = t;\n    }\n}\n\tclass Movie {\n\t\tconstructor(title, name, year, about, who, description, link, budget) {\n\t\t\tthis.title = title;\n\t\t\tthis.name = name;\n\t\t\tthis.year = year;\n\t\t\tthis.about = about;\n\t\t\tthis.who = who;\n\t\t\tthis.description = description;\n\t\t\tthis.link = link;\n\t\t\tthis.budget = budget;\n\t\t}\n\t}\n\nconst movies = [\n\tnew Movie(\"Lincoln\", \"Abraham Lincoln\", 2012, \"A film about\", \"Who was he?\", \"The 16th President of the United States.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_5fbaaIlZGQuyS9w\", \"$65m\"),\n\tnew Movie(\"The Imitation Game\", \"Alan Turing\", 2014, \"A film about\", \"Who was he?\", \"WWII codebreaker and mathematician.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_lt8SOqfiPYEve8v\", \"$14m\"),\n\tnew Movie(\"Hitchcock\", \"Alfred Hitchcock\", 2012, \"A film about\", \"Who was he?\", \"Master of suspense films.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_vkjN8DV7NhitKh1\", \"$15m\"),\n\tnew Movie(\"Moneyball\", \"Billy Beane\", 2011, \"A film about\", \"Who was he?\", \"Oakland Athletics' general manager.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_EysV527Oxg3kvYl\", \"$50m\"),\n\tnew Movie(\"Chaplin\", \"Charlie Chaplin\", 1992, \"A film about\", \"Who was he?\", \"Iconic silent film actor and director.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_wh8Qp1oGg9jAuQT\", \"$31m\"),\n\tnew Movie(\"Coco Before Chanel\", \"Coco Chanel\", 2009, \"A film about\", \"Who was she?\", \"Pioneering French fashion designer.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_ORgQxHhfRSnIP0G\", \"$23m\"),\n\tnew Movie(\"A Beautiful Day in the Neighborhood\", \"Fred Rogers\", 2019, \"A film about\", \"Who was he?\", \"An Iconic American children's television actor.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_LzAarCmwutJ1rB4\", \"$25m\"),\n\tnew Movie(\"W. A Life Misunderstood\", \"George W. Bush\", 2008, \"A film about\", \"Who was he?\", \"43rd U.S. President.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_2r31MjbxKSuatHG\", \"$25m\"),\n\tnew Movie(\"The Aviator\", \"Howard Hughes\", 2004, \"A film about\", \"Who was he?\", \"Aviation pioneer and filmmaker.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_XLQaWzmOs5R4kh9\", \"$110m\"),\n\tnew Movie(\"J. Edgar\", \"J. Edgar Hoover\", 2011, \"A film about\", \"Who was he?\", \"Founding FBI director.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_srTJeHyapmru8QL\", \"$35m\"),\n\tnew Movie(\"Oppenheimer\", \"J. Robert Oppenheimer\", 2023, \"A film about\", \"Who was he?\", \"The scientist behind the atomic bomb.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_PDJyESG2nl8Xlxv\", \"$100m\"),\n\tnew Movie(\"Tolkien\", \"J.R.R. Tolkien\", 2019, \"A film about\", \"Who was he?\", 'Author of \"The Lord of the Rings\" and \"The Hobbit\".', \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_gQaHT4YiHd3NDbM\", \"$20m\"),\n\tnew Movie(\"JFK\", \"Jim Garrison\", 1991, \"A film about\", \"Who was he?\", \"District attorney investigating JFK's assassination.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_o23X2kaRizdkolp\", \"$40m\"),\n\tnew Movie(\"The Doors\", \"Jim Morrison\", 1991, \"A film about\", \"Who was he?\", \"The Doors' charismatic lead singer.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_AqIEOIBuAEABzKR\", \"$38m\"),\n\tnew Movie(\"A Beautiful Mind\", \"John Nash\", 2001, \"A film about\", \"Who was he?\", \"Brilliant mathematician, Nobel laureate.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_2cqHELuIvk4XkSp\", \"$58m\"),\n\tnew Movie(\"Judy\", \"Judy Garland\", 2019, \"A film about\", \"Who was she?\", \"Legendary actress and singer.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_fE6S6vcJ7OORmv1\", \"$10m\"),\n\tnew Movie(\"The Iron Lady\", \"Margaret Thatcher\", 2011, \"A film about\", \"Who was she?\", \"UK's first female Prime Minister.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_OTfWWKWcNSQ0c3o\", \"$14m\"),\n\tnew Movie(\"Marie Antoinette\", \"Marie Antoinette\", 2006, \"A film about\", \"Who was she?\", \"Last Queen of France before the Revolution.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_0U7fQ8xRLz47qxu\", \"$40m\"),\n\tnew Movie(\"Nixon\", \"Richard Nixon\", 1995, \"A film about\", \"Who was he?\", \"37th U.S. President.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_rijMhfUN6wCASqn\", \"$16.5m\"),\n\tnew Movie(\"On The Basis of Sex\", \"Ruth Bader Ginsburg\", 2018, \"A film about\", \"Who was she?\", \"Supreme Court Justice.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_ORhOF1sOilfVlWZ\", \"$20m\"),\n\tnew Movie(\"Jobs\", \"Steve Jobs\", 2013, \"A film about\", \"Who was he?\", \"Co-founder of Apple Inc.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_DaZIN0jjmmQ25wS\", \"$12m\"),\n\tnew Movie(\"Capote\", \"Truman Capote\", 2005, \"A film about\", \"Who was he?\", \"Famed American writer.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_obooSA9ReKj6xwZ\", \"$7m\"),\n\tnew Movie(\"Braveheart\", \"William Wallace\", 1995, \"A film about\", \"Who was he?\", \"Scottish freedom fighter.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_WqoTG8pJUfiTj3m\", \"$10m\"),\n\tnew Movie(\"The Darkest Hour\", \"Winston Churchill\", 2017, \"A film about\", \"Who was he?\", \"British Prime Minister during WWII.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_qz2IsLXarG0MgVT\", \"$41m\"),\n\tnew Movie(\"Amadeus\", \"Wolfgang Amadeus Mozart\", 1984, \"A film about\", \"Who was he?\", \"Renowned classical composer.\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_MarXhTDt7SxWbNU\", \"$20m\")\n];\n\n\t\n\tshuffleArray(movies, seed);\n\t\n\t\/\/ Instruction paragraph\n\tvar instructionPara = document.createElement('p');\n\tinstructionPara.innerHTML = \"Please select the <b>6 biopics<\/b> you would like to include in the Facebook advertisement.<br><br>\";\n\tinstructionPara.style.fontWeight = 'bold'; \/\/ Make the text bold\n\tinstructionPara.style.fontSize = '18px';   \/\/ Increase font size to 18px\n\tthis.getQuestionContainer().appendChild(instructionPara);\n\n    \/\/ Create a table and style it\n    var table = document.createElement('table');\n    table.style.borderCollapse = 'collapse';\n    table.style.width = '100%';\n    table.style.color = 'black';\n\n    \/\/ Calculate rows and columns\n    var rows = 5;\n    var cols = 5;\n    var selectedMovies = [];\n\n\t\/\/ Handles the logic for selecting\/deselecting a movie cell\n\tfunction handleMovieClick(cell, movieTitle) {\n\t\tif(cell.classList.contains('selected')) {\n\t\t\tcell.classList.remove('selected');\n\t\t\tselectedMovies = selectedMovies.filter(title => title !== movieTitle);\n\t\t} else if(selectedMovies.length < 6) {\n\t\t\tcell.classList.add('selected');\n\t\t\tselectedMovies.push(movieTitle);\n\t\t}\n\n\t\tif (selectedMovies.length === 6) {\n\t\t\t\/\/ Save the selected movies as embedded data\n\t\t\tfor (let i = 0; i < selectedMovies.length; i++) {\n\t\t\t\tvar embeddedVariableName = 'choice-' + (i + 1); \n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData(embeddedVariableName, selectedMovies[i]);\n\t\t\t}\n\t\t}\n\t\tcheckSelections();\n\t}\n\t\n\t\t\/\/ Function to check whether 6 movies are selected\n\tfunction checkSelections() {\n\t\tlet nextButton = document.querySelector('#NextButton');\n\t\tif (selectedMovies.length === 6) {\n\t\t\tnextButton.style.pointerEvents = 'auto';\n\t\t\tnextButton.style.opacity = '1';\n\t\t} else {\n\t\t\tnextButton.style.pointerEvents = 'none';\n\t\t\tnextButton.style.opacity = '0.5';\n\t\t}\n\t}\n\n\t\/\/ Initially disable the NextButton\n\tcheckSelections();\n\n    for (var i = 0; i < rows; i++) {\n        var row = document.createElement('tr');\n        for (var j = 0; j < cols; j++) {\n            var index = i * cols + j;\n\n            var cell = document.createElement('td');\n\n            if (index < movies.length) {\n                var movie = movies[index];\n\n                \/\/ Create img element and add the link\n                var img = document.createElement('img');\n                img.src = movie.link;\n                img.style.width = '100px';\n\t\t\t\timg.style.height = '150px'\n\t\t\t\t\/\/img.style.display = 'block'; \/\/ To ensure it takes up the full width when centered\n            \timg.style.margin = '0 auto'; \/\/ To center the image\n\n                \/\/ Add img and other details to cell\n\t\t\tcell.innerHTML = img.outerHTML + \"<br>\" + \n\t\t\t\tmovie.about + \"<br>\" + \n\t\t\t\t\"<b>\" + movie.name + \"<\/b><br>\" + \n\t\t\t\t\"<u>\" + movie.who + \"<\/u><br>\" + \n\t\t\t\tmovie.description + \"<br>\" +  \n\t\t\t\t\"<u>Year:<\/u> \" + movie.year + \"<br>\" + \n\t\t\t\t\"<u>Budget:<\/u> \" + movie.budget + \"\";\n\n\n                \/\/ Add click event to select the movie from the table\n                cell.addEventListener('click', function(movieTitle) {\n                    return function() {\n                        handleMovieClick(this, movieTitle);\n                    };\n                }(movie.title)); \/\/ Pass the current movie title into the event function\n            }\n\n            \/\/ Style cell\n            cell.style.border = '1px solid black';\n            cell.style.padding = '10px';\n            cell.style.cursor = 'pointer';\n            row.appendChild(cell);\n\t\t\tcell.style.textAlign = 'center';     \/\/ Center align content horizontally\n        \tcell.style.verticalAlign = 'top';    \/\/ Top align content vertically\n        }\n        table.appendChild(row);\n    }\n\n    \/\/ Add styles for the selected class\n    var style = document.createElement('style');\n    style.innerHTML = `\n        td.selected {\n            background-color: #ffdd99; \/* Change this to your desired highlight color *\/\n        }\n    `;\n    document.head.appendChild(style);\n\n    \/\/ Add the table to the survey question\n    this.getQuestionContainer().appendChild(table);\n\n});\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"code","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID5"}},{"SurveyID":"SV_3y2GHRkJ8RpoNka","Element":"SQ","PrimaryAttribute":"QID28","SecondaryAttribute":"${e:\/\/Field\/choice-1}","TertiaryAttribute":null,"Payload":{"Quest