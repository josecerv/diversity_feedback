trics.SurveyEngine.addOnReady(function() {\n\t\n\tlet seed = Math.floor(Math.random() * 100000);\n\tQualtrics.SurveyEngine.setEmbeddedData('randomSeed', seed);\n\t\n\tfunction shuffleArray(array, seed) {\n    var m = array.length, t, i;\n\n    \/\/ Use the seed to have consistent random values\n    var random = function() {\n        var x = Math.sin(seed++) * 10000;\n        return x - Math.floor(x);\n    };\n\n    while (m) {\n        i = Math.floor(random() * m--);\n\n        t = array[m];\n        array[m] = array[i];\n        array[i] = t;\n    }\n}\n\tclass Biography {\n\t\tconstructor(name, published, about, who, description, link, pages) {\n\t\t\tthis.name = name;\n\t\t\tthis.published = published;\n\t\t\tthis.about = about;\n\t\t\tthis.who = who;\n\t\t\tthis.description = description;\n\t\t\tthis.link = link;\n\t\t\tthis.pages = pages;\n\t\t}\n\t}\n\nconst biographies = [\n    new Biography(\"Steve Jobs\", \"Published in 2011.\", \"A biography of\", \"Who was he?\", \"Apple Co-Founder\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_yqilFqdkilOTHaQ\", \"(656 pages)\"),\n    new Biography(\"J. Robert Oppenheimer\", \"Published in 2006.\", \"A biography of\", \"Who was he?\", \"Theoretical Physicist\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_HgsYywPRJz7tjx9\", \"(721 pages)\"),\n    new Biography(\"Mark Twain\", \"Published in 2010.\", \"A biography of\", \"Who was he?\", \"Writer\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_Pk1VamfdepoVuwu\", \"(736 pages)\"),\n    new Biography(\"Nelson Mandela\", \"Published in 1995.\", \"A biography of\", \"Who was he?\", \"Anti-apartheid Revolutionary\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_d0TCr4hakXiXaAi\", \"(656 pages)\"),\n    new Biography(\"Anthony Bourdain\", \"Published in 2007.\", \"A biography of\", \"Who was he?\", \"Chef and TV Personality\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_x2ua91RF5OgER9f\", \"(312 pages)\"),\n    new Biography(\"Andrew Jackson\", \"Published in 2009.\", \"A biography of\", \"Who was he?\", \"7th U.S. President\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_52wiJpWCDFiEmc8\", \"(512 pages)\"),\n    new Biography(\"Anne Frank\", \"Published in 1993.\", \"A biography of\", \"Who was she?\", \"Diarist during the Holocaust\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_Iaay9nCelm4YLfG\", \"(283 pages)\"),\n    new Biography(\"Tina Fey\", \"Published in 2013.\", \"A biography of\", \"Who is she?\", \"Comedian and Actress\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_WXqnDon0GOmaHBY\", \"(272 pages)\"),\n    new Biography(\"Johnny Cash\", \"Published in 2003.\", \"A biography of\", \"Who was he?\", \"Musician\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_aUVsyNGh0ZA3D7G\", \"(320 pages)\"),\n    new Biography(\"Jackie Kennedy\", \"Published in 2023.\", \"A biography of\", \"Who was she?\", \"Former First Lady\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_yAEGrb9an0zaD3A\", \"(511 pages)\"),\n    new Biography(\"Helen Keller\", \"Published in 1996.\", \"A biography of\", \"Who was she?\", \"Author and Activist\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_rf3mtX6ADq1usWk\", \"(80 pages)\"),\n    new Biography(\"Barbra Streisand\", \"Published in 2023.\", \"A biography of\", \"Who was she?\", \"Singer and Actress\", \"https:\/\/wharton.yul1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_hQ3k8WgOnpmDE59\", \"(992 pages)\"),\n    new Biography(\"Theodore Roosevelt\", \"Published in 2001.\", \"A biography of\", \"Who was he?\", \"26th U.S. President\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_iIPoKPcw48SkuwE\", \"(920 pages)\"),\n    new Biography(\"Che Guevara\", \"Published in 2003.\", \"A biography of\", \"Who was he?\", \"Revolutionary Leader\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_FRkRIpb5oAo8OOH\", \"(175 pages)\"),\n    new Biography(\"Jim Carroll\", \"Published in 1987.\", \"A biography of\", \"Who was he?\", \"Author\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_H90vJRN6zIsPOjH\", \"(224 pages)\"),\n    new Biography(\"Tennessee Williams\", \"Published in 2014.\", \"A biography of\", \"Who was he?\", \"Playwright\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_y2sjhiIwjXjcAjd\", \"(784 pages)\"),\n    new Biography(\"Keith Richards\", \"Published in 2011.\", \"A biography of\", \"Who is he?\", \"Musician\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_cp1EMKpaN6uTgUV\", \"(576 pages)\"),\n    new Biography(\"Napoleon Bonaparte\", \"Published in 2014.\", \"A biography of\", \"Who was he?\", \"Military Leader\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_IASY65r8ouijJls\", \"(976 pages)\"),\n    new Biography(\"Andre Agassi\", \"Published in 2010.\", \"A biography of\", \"Who is he?\", \"Tennis Player\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_LrAE1vpAlhW3aaR\", \"(400 pages)\"),\n    new Biography(\"Thomas Jefferson\", \"Published in 1998.\", \"A biography of\", \"Who was he?\", \"3rd U.S. President\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_CyUSCS5ZlWej6MG\", \"(440 pages)\"),\n    new Biography(\"Henry Winkler\", \"Published in 2023.\", \"A biography of\", \"Who is he?\", \"Actor\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_mgZNfgp2gNCYKZO\", \"(256 pages)\"),\n    new Biography(\"Robin Williams\", \"Published in 2019.\", \"A biography of\", \"Who was he?\", \"Comedian and Actor\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_xaFZJD8AZ2jec4L\", \"(560 pages)\"),\n    new Biography(\"Willie Nelson\", \"Published in 2016.\", \"A biography of\", \"Who is he?\", \"Musician\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_6wjrqgozeJnJ2hq\", \"(400 pages)\"),\n    new Biography(\"Michael J. Fox\", \"Published in 2020.\", \"A biography of\", \"Who is he?\", \"Actor\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_FtO0vTLADtDKjvO\", \"(256 pages)\"),\n    new Biography(\"John Stamos\", \"Published in 2023.\", \"A biography of\", \"Who is he?\", \"Actor and Musician\", \"https:\/\/upenn.co1.qualtrics.com\/ControlPanel\/Graphic.php?IM=IM_MVZx0AOpmnXCPfM\", \"(342 pages)\")\n];\n\n\t\n\tshuffleArray(biographies, seed);\n\t\n\t\/\/ Instruction paragraph\n\tvar instructionPara = document.createElement('p');\n\tinstructionPara.innerHTML = \"Please vote for the <b>6 biographies<\/b> you would like to include in the display.<br><br>\";\n\tinstructionPara.style.fontWeight = 'bold'; \/\/ Make the text bold\n\tinstructionPara.style.fontSize = '18px';   \/\/ Increase font size to 18px\n\tthis.getQuestionContainer().appendChild(instructionPara);\n\n    \/\/ Create a table and style it\n    var table = document.createElement('table');\n    table.style.borderCollapse = 'collapse';\n    table.style.width = '100%';\n    table.style.color = 'black';\n\n    \/\/ Calculate rows and columns\n    var rows = 5;\n    var cols = 5;\n    var selectedBiographies = [];\n\n\t\/\/ Handles the logic for selecting\/deselecting a biography cell\n\tfunction handleBiographyClick(cell, biographyName) {\n\t\tif(cell.classList.contains('selected')) {\n\t\t\tcell.classList.remove('selected');\n\t\t\tselectedBiographies = selectedBiographies.filter(name => name !== biographyName);\n\t\t} else if(selectedBiographies.length < 6) {\n\t\t\tcell.classList.add('selected');\n\t\t\tselectedBiographies.push(biographyName);\n\t\t}\n\n\t\tif (selectedBiographies.length === 6) {\n\t\t\t\/\/ Save the selected biographies as embedded data\n\t\t\tfor (let i = 0; i < selectedBiographies.length; i++) {\n\t\t\t\tvar embeddedVariableName = 'choice-' + (i + 1); \n\t\t\t\tconsole.log(embeddedVariableName);\n\t\t\t\tconsole.log(selectedBiographies[i]);\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData(embeddedVariableName, selectedBiographies[i]);\n\t\t\t}\n\t\t}\n\t\tcheckSelections();\n\t}\n\t\n\t\t\/\/ Function to check whether 6 biographies are selected\n\tfunction checkSelections() {\n\t\tlet nextButton = document.querySelector('#NextButton');\n\t\tif (selectedBiographies.length === 6) {\n\t\t\tnextButton.style.pointerEvents = 'auto';\n\t\t\tnextButton.style.opacity = '1';\n\t\t} else {\n\t\t\tnextButton.style.pointerEvents = 'none';\n\t\t\tnextButton.style.opacity = '0.5';\n\t\t}\n\t}\n\n\t\/\/ Initially disable the NextButton\n\tcheckSelections();\n\n    for (var i = 0; i < rows; i++) {\n        var row = document.createElement('tr');\n        for (var j = 0; j < cols; j++) {\n            var index = i * cols + j;\n\n            var cell = document.createElement('td');\n\n            if (index < biographies.length) {\n                var biography = biographies[index];\n\n                \/\/ Create img element and add the link\n                var img = document.createElement('img');\n                img.src = biography.link;\n                img.style.width = '100px';\n\t\t\t\timg.style.height = '150px'\n\t\t\t\t\/\/img.style.display = 'block'; \/\/ To ensure it takes up the full width when centered\n            \timg.style.margin = '0 auto'; \/\/ To center the image\n\n                \/\/ Add img and other details to cell\n\t\t\tcell.innerHTML = img.outerHTML + \"<br>\" + \n\t\t\t\tbiography.about + \"<br>\" + \n\t\t\t\t\"<b>\" + biography.name + \"<\/b><br>\" + \n\t\t\t\tbiography.pages + \"<br>\" + \n\t\t\t\tbiography.published + \"<br>\" + \n\t\t\t\t\"<u>\" + biography.who + \"<\/u><br>\" +\n\t\t\t\tbiography.description + \"\";\n\n                \/\/ Add click event to select the biography from the table\n                cell.addEventListener('click', function(biographyName) {\n                    return function() {\n                        handleBiographyClick(this, biographyName);\n                    };\n                }(biography.name)); \/\/ Pass the current biography name into the event function\n            }\n\n            \/\/ Style cell\n            cell.style.border = '1px solid black';\n            cell.style.padding = '10px';\n            cell.style.cursor = 'pointer';\n            row.appendChild(cell);\n\t\t\tcell.style.textAlign = 'center';     \/\/ Center align content horizontally\n        \tcell.style.verticalAlign = 'top';    \/\/ Top align content vertically\n        }\n        table.appendChild(row);\n    }\n\n    \/\/ Add styles for the selected class\n    var style = document.createElement('style');\n    style.innerHTML = `\n        td.selected {\n            background-color: #ffdd99; \/* Change this to your desired highlight color *\/\n        }\n    `;\n    document.head.appendChild(style);\n\n    \/\/ Add the table to the survey question\n    this.getQuestionContainer().appendChild(table);\n\n});\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"code","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID5"}},{"SurveyID":"SV_1BJC5tq7iCTDLpk","Element":"SQ","PrimaryAttribute":"QID28","SecondaryAttribute":"${e:\/\/Field\/choice-1}","TertiaryAttribute":null,"Payload":{"QuestionText":"${e:\/\/Field\/choice-1}","DefaultChoices":false,"DataExportTag":"Q28","QuestionID":"QID28","QuestionType":"DB","Selector":"TB","Configuration