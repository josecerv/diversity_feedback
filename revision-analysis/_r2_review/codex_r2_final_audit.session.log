import pandas as pd, numpy as np, math
from scipy import stats
p=r'C:\\Users\\jcerv\\Jose\\diversity_feedback\\Survey1_NPR_AttributeImportance_canonical_SV_aeIi4xABcJiz1vU.csv'
df=pd.read_csv(p,dtype=str,keep_default_na=False,na_values=['']).iloc[2:].reset_index(drop=True)
f=(df['Finished'].isin(['True','TRUE','1','true']) & df['Status'].isin(['IP Address','0']) &
   df['attribute'].notna() & df['attribute'].astype(str).str.strip().ne('') &
   df['ec_2'].fillna('').astype(str).str.strip().str.lower().isin(['one one','\"one one\"']))
df=df[f].copy(); df['importance_num']=pd.to_numeric(df['importance'], errors='coerce'); df=df[df['importance_num'].notna()]
attrs=['were women.','were under 50 years old.','were based on the West Coast of the United States.','worked at a university.']
print('N',len(df), df['attribute'].value_counts().to_dict())
for a in attrs:
 v=df[df.attribute.eq(a)].importance_num.astype(float).to_numpy(); print(a,len(v),np.mean(v),np.std(v,ddof=1))
x=df[df.attribute.eq(attrs[0])].importance_num.astype(float).to_numpy()
for a in attrs[1:]:
 y=df[df.attribute.eq(a)].importance_num.astype(float).to_numpy(); res=stats.ttest_ind(x,y,equal_var=False)
 n1,n2=len(x),len(y); v1=np.var(x,ddof=1); v2=np.var(y,ddof=1); dfw=(v1/n1+v2/n2)**2/((v1/n1)**2/(n1-1)+(v2/n2)**2/(n2-1)); sp=math.sqrt(((n1-1)*v1+(n2-1)*v2)/(n1+n2-2)); d=(np.mean(x)-np.mean(y))/sp
 print(a, 't',res.statistic,'df',dfw,'p',res.pvalue,'d',d,'diff',np.mean(x)-np.mean(y))
